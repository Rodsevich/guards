    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch minimal example [development]",
            "request": "launch",
            "type": "dart",
            "cwd": "example/minimal",
            "program": "lib/main.dart",
        },
        {
            "name": "Launch complex BLoC example [development]",
            "request": "launch",
            "type": "dart",
            "cwd": "example/complex_bloc/",
            "program": "lib/main_development.dart",
            "args": [
                "--target",
                "lib/main_development.dart"
            ]
        },
        {
            "name": "Launch complex BLoC example [staging]",
            "request": "launch",
            "type": "dart",
            "cwd": "example/complex_bloc/",
            "program": "lib/main_staging.dart",
            "args": [
                "--target",
                "lib/main_staging.dart"
            ]
        },
        {
            "name": "Launch complex BLoC example [production]",
            "request": "launch",
            "type": "dart",
            "cwd": "example/complex_bloc/",
            "program": "lib/main_production.dart",
            "args": [
                "--target",
                "lib/main_production.dart"
            ]
        }
    ]
}